<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>File Server</title>
    <script src="/socket.io/socket.io.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-color: #4361ee;
            --secondary-color: #3f37c9;
            --light-color: #f8f9fa;
            --dark-color: #212529;
        }
        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background-color: #f5f7fa;
            color: var(--dark-color);
            line-height: 1.6;
        }
        .container {
            max-width: 800px;
            margin: 2rem auto;
            padding: 2rem;
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        h1 {
            color: var(--primary-color);
            margin-bottom: 1.5rem;
            font-weight: 600;
        }
        .file-list {
            margin: 2rem 0;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            overflow: hidden;
        }
        .file-item {
            padding: 1rem;
            display: flex;
            align-items: center;
            transition: background-color 0.2s;
        }
        .file-item:hover {
            background-color: var(--light-color);
        }
        .file-item a {
            color: var(--primary-color);
            text-decoration: none;
            flex-grow: 1;
            display: flex;
            align-items: center;
        }
        .file-item a:hover {
            color: var(--secondary-color);
            text-decoration: underline;
        }
        .file-icon {
            margin-right: 0.75rem;
            color: #6c757d;
        }
        .file-name {
            flex-grow: 1;
            cursor: pointer;
        }
        .file-name:hover {
            color: var(--primary-color);
        }
        .file-size {
            color: #6c757d;
            font-size: 0.85rem;
            margin-left: auto;
            margin-right: 1rem;
        }
        .path-breadcrumb {
            padding: 0.5rem 1rem;
            background-color: #e9ecef;
            font-size: 0.9rem;
        }
        .path-breadcrumb a {
            color: var(--primary-color);
            text-decoration: none;
        }
        .path-breadcrumb a:hover {
            text-decoration: underline;
        }
        .upload-form {
            margin-top: 2rem;
            padding: 1.5rem;
            background-color: var(--light-color);
            border-radius: 8px;
        }
        .message-board {
            margin-top: 2rem;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            overflow: hidden;
        }
        .message-item {
            padding: 1rem;
            border-bottom: 1px solid #e9ecef;
        }
        .message-item:last-child {
            border-bottom: none;
        }
        .message-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.5rem;
        }
        .message-name {
            font-weight: 600;
            color: var(--primary-color);
        }
        .message-time {
            font-size: 0.85rem;
            color: #6c757d;
        }
        .message-content {
            color: var(--dark-color);
            word-break: break-word;
        }
        .btn-primary {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
        }
        .btn-primary:hover {
            background-color: var(--secondary-color);
            border-color: var(--secondary-color);
        }
        .messages-container {
            max-height: 400px;
            overflow-y: auto;
        }
        .no-messages {
            padding: 2rem;
            text-align: center;
            color: #6c757d;
        }
        @media (max-width: 576px) {
            .container {
                padding: 1rem;
                margin: 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1 class="text-center">📁 File Server</h1>
        
        <div class="file-list">
            <div class="file-item bg-light">
                <h5 class="mb-0">📂 文件浏览器</h5>
            </div>
            <div id="path-breadcrumb" class="path-breadcrumb">
                <a href="#" onclick="loadDirectory(''); return false;">根目录</a>
            </div>
            <div id="file-list-container">
                <div class="file-item text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>

            <script>
                let currentPath = '';

                // HTML转义函数（全局使用）
                function escapeHtml(text) {
                    const div = document.createElement('div');
                    div.textContent = text;
                    return div.innerHTML;
                }

                // 格式化文件大小
                function formatSize(bytes) {
                    if (bytes === 0) return '';
                    const units = ['B', 'KB', 'MB', 'GB'];
                    let i = 0;
                    while (bytes >= 1024 && i < units.length - 1) {
                        bytes /= 1024;
                        i++;
                    }
                    return bytes.toFixed(i > 0 ? 1 : 0) + ' ' + units[i];
                }

                // 格式化日期
                function formatDate(date) {
                    return new Date(date).toLocaleDateString('zh-CN', {
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                }

                // 更新路径面包屑
                function updateBreadcrumb(path) {
                    const container = document.getElementById('path-breadcrumb');
                    const parts = path ? path.split('/').filter(p => p) : [];

                    let html = '<a href="#" onclick="loadDirectory(\'\'); return false;">根目录</a>';

                    let accumulated = '';
                    parts.forEach((part, index) => {
                        accumulated += (accumulated ? '/' : '') + part;
                        const p = accumulated;
                        html += ' / <a href="#" onclick="loadDirectory(\'' + p + '\'); return false;">' + escapeHtml(part) + '</a>';
                    });

                    container.innerHTML = html;
                }

                // 更新上传目标目录显示
                function updateUploadTarget() {
                    const uploadTarget = document.getElementById('upload-target');
                    if (uploadTarget) {
                        uploadTarget.textContent = '上传到: ' + (currentPath || '根目录');
                    }
                }

                function loadDirectory(path) {
                    currentPath = path || '';
                    const container = document.getElementById('file-list-container');

                    updateBreadcrumb(currentPath);
                    updateUploadTarget(); // 更新上传目标

                    // Show loading state
                    container.innerHTML = `
                        <div class="file-item text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    `;

                    // Fetch directory contents
                    fetch('/api/browse?path=' + encodeURIComponent(currentPath))
                        .then(response => {
                            if (!response.ok) throw new Error('Failed to load directory');
                            return response.json();
                        })
                        .then(items => {
                            if (!items || items.length === 0) {
                                container.innerHTML = `
                                    <div class="file-item text-center py-4">
                                        <p class="text-muted mb-0">目录为空</p>
                                    </div>
                                `;
                                return;
                            }

                            // 添加返回上级目录按钮
                            let html = '';
                            if (currentPath) {
                                const parentPath = currentPath.split('/').slice(0, -1).join('/');
                                html += `
                                    <div class="file-item">
                                        <span class="file-icon">📤</span>
                                        <span class="file-name" onclick="loadDirectory('${parentPath}')">..</span>
                                        <span class="badge bg-secondary ms-auto">上级目录</span>
                                    </div>
                                `;
                            }

                            // 渲染文件和目录
                            items.forEach(item => {
                                const icon = item.isDirectory ? '📁' : getFileIcon(item.name);
                                const itemPath = currentPath ? `${currentPath}/${item.name}` : item.name;

                                if (item.isDirectory) {
                                    html += `
                                        <div class="file-item">
                                            <span class="file-icon">${icon}</span>
                                            <span class="file-name" onclick="loadDirectory('${itemPath}')">${escapeHtml(item.name)}</span>
                                            <span class="badge bg-secondary ms-auto">目录</span>
                                        </div>
                                    `;
                                } else {
                                    html += `
                                        <div class="file-item">
                                            <span class="file-icon">${icon}</span>
                                            <a href="/${itemPath}" target="_blank">${escapeHtml(item.name)}</a>
                                            <span class="file-size">${formatSize(item.size)}</span>
                                            <span class="badge bg-light text-dark">${formatDate(item.modified)}</span>
                                        </div>
                                    `;
                                }
                            });

                            container.innerHTML = html;
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            container.innerHTML = `
                                <div class="file-item text-center py-4">
                                    <p class="text-danger mb-0">加载失败: ${error.message}</p>
                                </div>
                            `;
                        });
                }

                // 根据文件扩展名获取图标
                function getFileIcon(filename) {
                    const ext = filename.split('.').pop().toLowerCase();
                    const icons = {
                        'jpg': '🖼️', 'jpeg': '🖼️', 'png': '🖼️', 'gif': '🖼️', 'webp': '🖼️', 'svg': '🖼️',
                        'mp3': '🎵', 'wav': '🎵', 'ogg': '🎵', 'flac': '🎵',
                        'mp4': '🎬', 'mkv': '🎬', 'avi': '🎬', 'mov': '🎬', 'webm': '🎬',
                        'pdf': '📄', 'doc': '📄', 'docx': '📄', 'xls': '📊', 'xlsx': '📊',
                        'zip': '📦', 'rar': '📦', '7z': '📦', 'tar': '📦', 'gz': '📦',
                        'js': '📜', 'ts': '📜', 'py': '📜', 'json': '📜', 'html': '📜', 'css': '📜',
                        'txt': '📝', 'md': '📝'
                    };
                    return icons[ext] || '📄';
                }

                // Initial load
                loadDirectory(currentPath);
            </script>

            <script>
                // WebSocket连接
                const socket = io();
                
                socket.on('connect', () => {
                    console.log('WebSocket已连接');
                    document.getElementById('ws-status').innerHTML = '<span class="badge bg-success">WebSocket: 已连接</span>';
                });
                
                socket.on('disconnect', () => {
                    console.log('WebSocket已断开');
                    document.getElementById('ws-status').innerHTML = '<span class="badge bg-danger">WebSocket: 已断开</span>';
                });
                
                socket.on('welcome', (data) => {
                    console.log('收到欢迎消息:', data);
                });
                
                socket.on('echo', (data) => {
                    console.log('收到回显消息:', data);
                });
                
                socket.on('filesList', (data) => {
                    console.log('收到文件列表:', data);
                });
                
                // 发送测试消息
                function sendTestMessage() {
                    socket.emit('message', { message: 'Hello from client!' });
                }
                
                // 请求文件列表
                function requestFiles() {
                    socket.emit('getFiles', {});
                }
            </script>
        </div>
        
        <div class="upload-form">
            <h5 class="mb-3">⬆️ 上传 文件</h5>
            <form id="upload-form" class="row g-2">
                <div class="col-md-8">
                    <input class="form-control" type="file" name="file" id="upload-file" required>
                    <input type="hidden" name="path" id="upload-path">
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <span id="upload-btn-text">上传文件</span>
                        <span id="upload-spinner" class="spinner-border spinner-border-sm d-none"></span>
                    </button>
                </div>
            </form>
            <div class="mt-2 text-muted small" id="upload-target">
                上传到: 根目录
            </div>
            <script>
                // 文件上传
                document.getElementById('upload-form').addEventListener('submit', async function(e) {
                    e.preventDefault();

                    const fileInput = document.getElementById('upload-file');
                    const file = fileInput.files[0];
                    if (!file) {
                        alert('请选择文件');
                        return;
                    }

                    const btnText = document.getElementById('upload-btn-text');
                    const spinner = document.getElementById('upload-spinner');

                    // 检查文件是否存在
                    try {
                        const checkRes = await fetch('/api/check-file?path=' + encodeURIComponent(currentPath) + '&name=' + encodeURIComponent(file.name));
                        const checkData = await checkRes.json();

                        if (checkData.exists) {
                            const confirmed = confirm('文件 "' + file.name + '" 已存在，是否覆盖？');
                            if (!confirmed) {
                                return;
                            }
                        }
                    } catch (err) {
                        console.error('检查文件失败:', err);
                    }

                    const formData = new FormData();
                    formData.append('file', file);

                    btnText.textContent = '上传中...';
                    spinner.classList.remove('d-none');

                    fetch('/upload?path=' + encodeURIComponent(currentPath), {
                        method: 'POST',
                        body: formData
                    })
                    .then(res => res.json())
                    .then(data => {
                        btnText.textContent = '上传文件';
                        spinner.classList.add('d-none');

                        if (data.error) {
                            alert('上传失败: ' + data.error);
                        } else {
                            fileInput.value = '';
                            loadDirectory(currentPath); // 刷新文件列表
                        }
                    })
                    .catch(err => {
                        btnText.textContent = '上传文件';
                        spinner.classList.add('d-none');
                        alert('上传失败，请重试');
                        console.error(err);
                    });
                });
            </script>
            <div class="mt-3">
                <div id="ws-status" class="mb-2">
                    <span class="badge bg-secondary">WebSocket: 未连接</span>
                </div>
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="sendTestMessage()">发送测试消息</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="requestFiles()">请求文件列表</button>
            </div>
        </div>

        <!-- 留言板 -->
        <div class="message-board">
            <div class="file-item bg-light">
                <h5 class="mb-0">💬 留言板</h5>
            </div>

            <!-- 留言表单 -->
            <div class="p-3 border-bottom">
                <form id="message-form" class="row g-2">
                    <div class="col-md-3">
                        <input type="text" class="form-control" id="msg-name" placeholder="您的昵称（可选）" maxlength="20">
                    </div>
                    <div class="col-md-6">
                        <input type="text" class="form-control" id="msg-content" placeholder="输入留言内容..." maxlength="500" required>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100">发送留言</button>
                    </div>
                </form>
            </div>

            <!-- 留言列表 -->
            <div id="messages-container" class="messages-container">
                <div class="no-messages">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    加载中...
                </div>
            </div>

            <script>
                // 加载留言列表
                function loadMessages() {
                    fetch('/api/messages')
                        .then(res => res.json())
                        .then(messages => {
                            const container = document.getElementById('messages-container');

                            if (!messages || messages.length === 0) {
                                container.innerHTML = '<div class="no-messages">暂无留言，快来发表第一条吧！</div>';
                                return;
                            }

                            container.innerHTML = messages.map(msg => `
                                <div class="message-item">
                                    <div class="message-header">
                                        <span class="message-name">👤 ${escapeHtml(msg.name)}</span>
                                        <span class="message-time">${formatTime(msg.timestamp)}</span>
                                    </div>
                                    <div class="message-content">${escapeHtml(msg.content)}</div>
                                </div>
                            `).join('');
                        })
                        .catch(err => {
                            console.error('加载留言失败:', err);
                            document.getElementById('messages-container').innerHTML =
                                '<div class="no-messages text-danger">加载留言失败</div>';
                        });
                }

                // 提交留言
                document.getElementById('message-form').addEventListener('submit', function(e) {
                    e.preventDefault();

                    const name = document.getElementById('msg-name').value.trim();
                    const content = document.getElementById('msg-content').value.trim();

                    if (!content) {
                        alert('请输入留言内容');
                        return;
                    }

                    fetch('/api/messages', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ name, content })
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.error) {
                            alert(data.error);
                            return;
                        }
                        document.getElementById('msg-content').value = '';
                        loadMessages();
                    })
                    .catch(err => {
                        console.error('发送留言失败:', err);
                        alert('发送失败，请重试');
                    });
                });

                // WebSocket实时接收新留言
                socket.on('newMessage', (msg) => {
                    console.log('收到新留言:', msg);
                    loadMessages();
                });

                // 格式化时间
                function formatTime(isoString) {
                    const date = new Date(isoString);
                    return date.toLocaleString('zh-CN', {
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                }

                // 初始加载留言
                loadMessages();
            </script>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>